# ============================================================
# terraform.tfvars — Copy to terraform.tfvars and fill in.
#
# terraform.tfvars is .gitignored (both at repo root and in
# ndm/ddlab-automation/.gitignore) — it contains secrets.
# This .example file MUST NOT contain real credentials.
# ============================================================

# ── GCP ─────────────────────────────────────────────────────
gcp_project         = "<your-gcp-project-id>"
gcp_region          = "asia-southeast1"
gcp_zone            = "asia-southeast1-a"
gce_service_account = "<numeric-id>-compute@developer.gserviceaccount.com"

# ── SSH Access ──────────────────────────────────────────────
# Paste the contents of your ~/.ssh/id_ed25519.pub (or id_rsa.pub).
# SSH uses Google IAP tunnel — no public IP is created:
#   gcloud compute ssh labuser@ddlab-ndm --tunnel-through-iap
ssh_public_key = "ssh-ed25519 <YOUR_PUBLIC_KEY_CONTENT> <your@email.com>"

# ── Datadog ──────────────────────────────────────────────────
# DO NOT put the API key here. It is loaded from .env at apply time:
#   1) Put   DD_API_KEY=<your-key>   in ./.env
#   2) Before running terraform:
#        set -a && source .env && set +a
#        export TF_VAR_dd_api_key="$DD_API_KEY"
# If unset, Terraform will prompt for it interactively.
dd_site      = "us3.datadoghq.com"   # allowed: datadoghq.com | us3.datadoghq.com | us5.datadoghq.com
dd_namespace = "lab-th"              # NDM namespace — groups all lab devices

# ── SNMP Credentials ─────────────────────────────────────────
# Used by the 5 CSR1000v SNMPv3 config AND the Datadog Agent SNMP check.
# Replace with strong values of your own (min 8 chars for auth/priv).
snmp_community    = "<change-me-community>"
snmp_v3_user      = "<change-me-user>"
snmp_v3_auth_pass = "<CHANGE_ME_AUTH_PASS>"
snmp_v3_priv_pass = "<CHANGE_ME_PRIV_PASS>"

# ── Device Password (IOS enable / username) ──────────────────
device_password = "<CHANGE_ME_DEVICE_PASS>"

# ── CSR1000v image tag ───────────────────────────────────────
# Must match the tag `build-images.sh` produced from your licensed qcow2.
# Check with: docker images | grep vrnetlab
csr_image_tag = "vrnetlab/cisco_csr1000v:<version-you-built>"

# ── BGP ──────────────────────────────────────────────────────
bgp_local_as = 65000   # CSR1-5 iBGP AS
bgp_peer_as  = 65001   # FRR (bgp-peer) eBGP AS — simulates upstream ISP

# ── Geomap — Thailand default ────────────────────────────────
# Bangkok — CSR1 (BKK-Edge)
geo_bkk_lat   = "13.7563"
geo_bkk_lon   = "100.5018"
geo_bkk_label = "Bangkok-DC1"
# Chiang Mai — CSR3/4/5 (CNX-Edge, -Access, -Endpoint)
geo_cnx_lat   = "18.7883"
geo_cnx_lon   = "98.9853"
geo_cnx_label = "ChiangMai-DC2"

# ── Optional overrides ───────────────────────────────────────
# Defaults fit 5 CSRs (4 GB QEMU RAM each + agent + OS).
machine_type = "n2-standard-8"   # 8 vCPU / 32 GB
# disk_size_gb = 200
# lab_name     = "ddlab-ndm"
# subnet_cidr  = "10.100.0.0/24"

# Management IPs for each CSR (override only if conflicting with your env)
# csr_mgmt_ip  = "172.20.20.10"   # CSR1  (BKK-Edge)
# csr2_mgmt_ip = "172.20.20.11"   # CSR2  (WAN-Transit)
# csr3_mgmt_ip = "172.20.20.12"   # CSR3  (CNX-Edge)
# csr4_mgmt_ip = "172.20.20.14"   # CSR4  (CNX-Access)
# csr5_mgmt_ip = "172.20.20.15"   # CSR5  (CNX-Endpoint)

# Image cache bucket (created by Terraform; name defaults to
# <project>-<lab_name>-cache). Override only if you want a shared /
# pre-existing bucket.
# image_cache_bucket_name   = ""
# image_cache_force_destroy = false   # true = terraform destroy wipes the cache too

# pan_* and f5_* variables are DEPRECATED — the topology is CSR-only now.
# They remain as no-op placeholders so older tfvars files still parse.
# pan_image_tag  = ""
# f5_image_tag   = ""
# f5_license_key = ""
